{
  "productName": "M3U8 Harvester",
  "version": "1.0.1",
  "identifier": "com.m3u8-harvester.app",
  "build": {
    "beforeDevCommand": "pnpm --filter @m3u8-harvester/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @m3u8-harvester/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "M3U8 Harvester",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
